*
!.gitignore
!README.md

# Shell
!.zshrc##template

# tmux
!.tmux.conf##template
!tmux-work.sh

# Git
!.gitconfig##template
!/.ssh
!/.ssh/config##template

# systemd user services
!/.config
!/.config/direnv
!/.config/direnv/direnvrc
!/.config/systemd
!/.config/systemd/user
!/.config/systemd/user/ssh-agent.service

# Claude Code
!/.claude
!/.claude/settings.json
!/.claude/skills
!/.claude/skills/**

# dbt
!/.dbt
!/.dbt/profiles.yml##template

# Snowflake MCP
!snowflake_mcp_config.yaml

# Emacs (legacy)
!.emacs
!/.emacs.d*
!/.emacs.d/snippets*
!/.emacs.d/snippets/**/*
!/.emacs.d/simple-red-theme.el
!/.emacs.d/simple-red-theme-dark.el

# macOS
!/Library*
!/Library/LaunchAgents*
!/Library/LaunchAgents/com.jacobhak.emacs-daemon.plist
!/Library/KeyBindings*
!/Library/KeyBindings/DefaultKeyBinding.dict

# local scripts
!/.local
!/.local/bin
!/.local/bin/bootstrap-workflow
