# Simple prompt for tramp compatibility
if [[ "$TERM" == "dumb" ]]; then
    unsetopt zle
    PS1="$ "
    return
fi

export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"
plugins=(git)
source $ZSH/oh-my-zsh.sh

# pyenv
{% if yadm.os == "Darwin" %}
eval "$(pyenv init -)"
eval "$(pyenv virtualenv-init -)"
{% else %}
export PYENV_ROOT="$HOME/.pyenv"
[[ -d $PYENV_ROOT/bin ]] && export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init -)"
eval "$(pyenv virtualenv-init -)"
{% endif %}

# Google Cloud SDK
{% if yadm.os == "Darwin" %}
if [ -f '/Users/jacobhakansson/Downloads/google-cloud-sdk/path.zsh.inc' ]; then . '/Users/jacobhakansson/Downloads/google-cloud-sdk/path.zsh.inc'; fi
if [ -f '/Users/jacobhakansson/Downloads/google-cloud-sdk/completion.zsh.inc' ]; then . '/Users/jacobhakansson/Downloads/google-cloud-sdk/completion.zsh.inc'; fi
{% else %}
if [ -f "$HOME/google-cloud-sdk/path.zsh.inc" ]; then . "$HOME/google-cloud-sdk/path.zsh.inc"; fi
if [ -f "$HOME/google-cloud-sdk/completion.zsh.inc" ]; then . "$HOME/google-cloud-sdk/completion.zsh.inc"; fi
{% endif %}

# uv / pipx
export PATH="$PATH:$HOME/.local/bin"

# poetry
export PATH="$PATH:$HOME/.poetry/bin"

# direnv
if command -v direnv >/dev/null 2>&1; then
    eval "$(direnv hook zsh)"
fi

# fzf
{% if yadm.os == "Darwin" %}
source <(fzf --zsh)
{% else %}
source /usr/share/doc/fzf/examples/key-bindings.zsh
source /usr/share/doc/fzf/examples/completion.zsh
{% endif %}

# SSH agent (systemd-managed, fixed socket path)
{% if yadm.os == "Darwin" %}
{% else %}
if [ -z "${XDG_RUNTIME_DIR:-}" ] && [ -d "/run/user/$(id -u)" ]; then
    export XDG_RUNTIME_DIR="/run/user/$(id -u)"
fi
export SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/ssh-agent.socket"
if [ -S "$SSH_AUTH_SOCK" ] && [ -f ~/.ssh/id_ed25519 ]; then
    ssh-add -l >/dev/null 2>&1
    if [ $? -eq 1 ] || ! ssh-add -l 2>/dev/null | grep -Fq "$(ssh-keygen -lf ~/.ssh/id_ed25519.pub 2>/dev/null | awk '{print $2}')"; then
        ssh-add ~/.ssh/id_ed25519 2>/dev/null
    fi
fi
{% endif %}

# Pass SSH_TTY to tmux so clipetty/OSC 52 clipboard works over SSH
if [ -n "$TMUX" ] && [ -n "$SSH_TTY" ]; then
    tmux set-environment SSH_TTY "$SSH_TTY"
fi

alias tp='tmux-picker'

e() {
    if [ -n "${DISPLAY:-}" ] || [ -n "${WAYLAND_DISPLAY:-}" ]; then
        emacsclient -n -c "$@"
    else
        emacsclient -t "$@"
    fi
}

# Source local secrets/overrides (not tracked by yadm)
[ -f ~/.zshrc.local ] && source ~/.zshrc.local

# opencode
export PATH="$HOME/.opencode/bin:$PATH"

export EDITOR='emacs'
{% if yadm.os == "Darwin" %}
export EDITOR='emacsclient'
export PATH='$HOME/.duckdb/cli/latest':$PATH
{% endif %}
