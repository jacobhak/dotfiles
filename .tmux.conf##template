set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'
set -g @continuum-restore 'on'
set -g @continuum-save-interval '15'

set -g mouse on
set -g history-limit 100000
set -g allow-passthrough on
set -s set-clipboard on
set -as terminal-features ',xterm*:clipboard,screen*:clipboard,tmux-256color:clipboard,alacritty:clipboard,wezterm:clipboard,foot*:clipboard,kitty:clipboard'
setw -g aggressive-resize on
set -g prefix C-b
bind C-b send-prefix
set -g default-shell "${SHELL}"

bind '"' split-window -v -c "#{pane_current_path}"
bind % split-window -h -c "#{pane_current_path}"
bind c new-window -c "#{pane_current_path}"

set -g automatic-rename on
set -g automatic-rename-format '#{b:pane_current_path}'

{% if yadm.os == "Darwin" %}
bind-key O run-shell "tmux show-buffer | tr -d '\n' | xargs open"
run '/opt/homebrew/opt/tpm/share/tpm/tpm'
{% else %}
run '~/.tmux/plugins/tpm/tpm'
{% endif %}
